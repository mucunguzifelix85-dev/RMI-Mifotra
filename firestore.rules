rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidExam(data) {
      return data.title is string && data.title.size() > 0 &&
             data.durationMinutes is number && data.durationMinutes > 0 &&
             data.questions is list && data.questions.size() > 0 &&
             data.sessionCode is string && data.sessionCode.size() == 6;
    }

    function isValidSubmission(data) {
      return data.examId is string &&
             data.studentName is string && data.studentName.size() > 0 &&
             data.status in ['in-progress', 'submitted'];
    }

    match /exams/{examId} {
      allow read: if true;
      allow create, update, delete: if true; 
    }

    match /submissions/{submissionId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /violations/{violationId} {
      allow read: if true;
      allow create, delete: if true;
      allow update: if false;
    }
  }
}
